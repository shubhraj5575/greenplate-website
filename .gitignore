# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (DO NOT commit)
.env*
!.env.example

# vercel / netlify
.vercel
.netlify

# typescript
*.tsbuildinfo
next-env.d.ts

# scraper cache (Phase 1)
scripts/.cache/
scripts/.scraped/

# Supabase CLI working dir — contains pooler URL, project ref, version files
supabase/.temp/

# Deno lockfile (not used; Next.js / pnpm project)
deno.lock

# Curation work-log (per-row skipped during WebSearch verification)
data/.curated-skipped.txt
